[Version]
Signature   = "$Windows NT$"
Class       = "libusb-win32 devices"
ClassGUID   = {EB781AAF-9C70-4523-A5DF-642A87ECA567}
Provider    = QUALCOMM
CatalogFile = qcserlib.cat
DriverVer   = 08/04/2025, 1.0.0.1
PnpLockdown = 1

; ========== Manufacturer/Models sections ===========

[Manufacturer]
%QUALCOMM% = libusb_Devices, NTx86, NTamd64, NTarm64

[libusb_Install]
Include = winusb.inf
Needs   = WINUSB.NT

[libusb_Install.Services]
Include =winusb.inf
Needs   = WINUSB.NT.Services

[libusb_Install.HW]
AddReg=Dev_AddReg

[libusb_Install.Wdf]
KmdfService=WINUSB, WinUsb_Install

[WinUsb_Install]
KmdfLibraryVersion=1.11

[Dev_AddReg]
HKR,,DeviceInterfaceGUIDs,0x10000,"{90c66cac-9ae6-4464-9a67-6d27a5282c31}"

[ClassInstall32]
Addreg = libusb_class_install_add_reg

[libusb_class_install_add_reg]
HKR,,,0,"libusb-win32 devices"
HKR,,Icon,,-20

